generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ticket {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  title       String
  description String
  phase       String
  module      String @default("Geral")
  weight      Int
  completed   Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
